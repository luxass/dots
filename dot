_dot() {
  local -a commands
  commands=(
    'init:Initialize and install dotfiles'
    'update:Update dotfiles and packages'
    'doctor:Run diagnostics'
    'info:Show repository and runtime info'
    'links:Check managed symlinks'
    'hooks:Install repository Git hooks'
    'secret-scan:Scan repository for secrets'
    'package:Manage Homebrew bundle packages'
    'check-packages:Check bundle package state'
    'retry-failed:Retry failed package installs'
    'git-identity:Create or update local Git identity'
    'stow:Create symlinks using GNU Stow'
    'unstow:Remove stowed symlinks'
    'link:Install dot command globally'
    'unlink:Remove global dot command'
    'edit:Open dotfiles repo'
    'help:Show help'
  )
  _describe 'command' commands
}
_dot "$@"
EOF
}

