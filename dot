#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="dot"
readonly VERSION="1.2.0"
SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
readonly SCRIPT_PATH
DOTFILES_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
readonly DOTFILES_DIR
readonly PACKAGES_DIR="${DOTFILES_DIR}/packages"
readonly HOME_DIR="${DOTFILES_DIR}/home"
readonly BASE_BUNDLE="${PACKAGES_DIR}/bundle"
readonly FONTS_BUNDLE="${PACKAGES_DIR}/bundle.fonts"
readonly WORK_BUNDLE="${PACKAGES_DIR}/bundle.work"
readonly BACKUP_ROOT="${DOTFILES_DIR}/backups"
readonly PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
readonly NODE_RUNTIME_VERSION="${NODE_RUNTIME_VERSION:-lts}"
readonly PNPM_GLOBAL_PACKAGES=("sfw" "@earendil-works/pi-coding-agent:pi")

CURRENT_STEP=0
TOTAL_STEPS=0
DOT_VERBOSE="${DOT_VERBOSE:-false}"

source "${DOTFILES_DIR}/lib/core.sh"
source "${DOTFILES_DIR}/lib/config.sh"
source "${DOTFILES_DIR}/lib/brew.sh"
source "${DOTFILES_DIR}/lib/runtime.sh"
source "${DOTFILES_DIR}/lib/stow.sh"
source "${DOTFILES_DIR}/lib/git.sh"
source "${DOTFILES_DIR}/lib/pi.sh"
source "${DOTFILES_DIR}/lib/skills.sh"

TOOL_REGISTRY=(
  "Homebrew          ;; brew ;; fn:ensure_homebrew             ;; true  ;; - ;; true"
  "Brewfile packages ;; -    ;; fn:_install_packages           ;; true  ;; - ;; false"
  "Stow dotfiles     ;; -    ;; fn:_stow_dotfiles              ;; true  ;; - ;; false"
  "Fish shell        ;; fish ;; fn:_setup_fish_shell           ;; false ;; - ;; true"
  "pnpm              ;; pnpm ;; fn:ensure_pnpm                 ;; true  ;; - ;; true"
  "Node.js runtime   ;; node ;; fn:ensure_node_runtime         ;; true  ;; - ;; true"
  "pnpm globals      ;; -    ;; fn:ensure_pnpm_globals         ;; true  ;; - ;; false"
  "Git hooks         ;; -    ;; fn:ensure_git_hooks            ;; false ;; - ;; false"
  "Git identity      ;; -    ;; fn:ensure_gitconfig_local      ;; false ;; - ;; false"
  "dot CLI           ;; dot  ;; fn:_link_dot                   ;; true  ;; - ;; true"
  "Git               ;; git  ;; -                              ;; true  ;; - ;; true"
  "GNU Stow          ;; stow ;; fn:ensure_stow                 ;; true  ;; - ;; true"
  "Starship          ;; starship ;; -                          ;; false ;; - ;; true"
  "Zoxide            ;; zoxide ;; -                            ;; false ;; - ;; true"
  "Bun               ;; bun  ;; -                              ;; false ;; - ;; true"
  "Socket Firewall   ;; sfw  ;; -                              ;; false ;; - ;; true"
  "Pi                ;; pi   ;; -                              ;; false ;; - ;; true"
)

_parse_tool_entry() {
  local entry="$1"
  r_name="$(echo "$entry" | awk -F';;' '{print $1}' | xargs)"
  r_check="$(echo "$entry" | awk -F';;' '{print $2}' | xargs)"
  r_install="$(echo "$entry" | awk -F';;' '{print $3}' | xargs)"
  r_required="$(echo "$entry" | awk -F';;' '{print $4}' | xargs)"
  r_skip="$(echo "$entry" | awk -F';;' '{print $5}' | xargs)"
  r_doctor="$(echo "$entry" | awk -F';;' '{print $6}' | xargs)"
}

run_init_steps() {
  TOTAL_STEPS=0
  for entry in "${TOOL_REGISTRY[@]}"; do
    _parse_tool_entry "$entry"
    if [[ "$r_skip" != "-" && "${!r_skip:-}" == "true" ]]; then
      continue
    fi
    ((++TOTAL_STEPS))
  done

  CURRENT_STEP=0
  for entry in "${TOOL_REGISTRY[@]}"; do
    _parse_tool_entry "$entry"
    if [[ "$r_skip" != "-" && "${!r_skip:-}" == "true" ]]; then
      continue
    fi

    print_step "$r_name"
    if [[ "$r_install" == fn:* ]]; then
      local fn="${r_install#fn:}"
      if "$fn"; then
        true
      elif [[ "$r_required" == "true" ]]; then
        return 1
      else
        print_warning "$r_name failed; continuing"
      fi
    elif [[ "$r_check" != "-" ]] && command_exists "$r_check"; then
      print_success "$r_name is installed"
    elif [[ "$r_required" == "true" ]]; then
      print_error "$r_name is missing"
      return 1
    else
      print_warning "$r_name is missing"
    fi
  done
}

_setup_fish_shell() {
  if ! command_exists fish; then
    print_warning "Fish is not installed"
    return 1
  fi

  local fish_path
  fish_path="$(command -v fish)"

  if ! grep -qx "$fish_path" /etc/shells; then
    print_info "Adding Fish to /etc/shells"
    echo "$fish_path" | sudo tee -a /etc/shells >/dev/null
  fi

  if [[ "${SHELL:-}" != "$fish_path" ]]; then
    print_info "Setting Fish as the default shell"
    chsh -s "$fish_path"
    print_success "Default shell set to Fish; restart the terminal to use it"
  else
    print_success "Fish is already the default shell"
  fi

  if command_exists fisher; then
    print_info "Installing Fish plugins"
    fish -c "fisher install jhillyerd/plugin-git"
  fi
}

cmd_init() {
  print_header "Initializing dotfiles"
  run_init_steps
}

cmd_update() {
  print_header "Updating dotfiles"

  if git -C "$DOTFILES_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    print_info "Pulling latest repo changes"
    git -C "$DOTFILES_DIR" pull --ff-only
  fi

  print_info "Updating Homebrew"
  brew update
  brew_bundle_install_resilient "$BASE_BUNDLE"
  _stow_dotfiles

  if confirm "Update Pi and managed Pi packages/extensions?" "n"; then
    cmd_pi_update
  else
    print_info "Skipping Pi update"
  fi
}

cmd_info() {
  print_header "Dotfiles"
  echo "Version:            $VERSION"
  echo "Dotfiles directory: $DOTFILES_DIR"
  echo "Home package:       $HOME_DIR"
  echo "Packages:           $PACKAGES_DIR"
  echo "Backups:            $BACKUP_ROOT"
  echo

  print_header "Runtime"
  printf "Homebrew:           "
  command_exists brew && command -v brew || echo "missing"
  printf "pnpm:               "
  command_exists pnpm && command -v pnpm || echo "missing"
  printf "Node.js:            "
  command_exists node && node --version || echo "missing"
  printf "npm:                "
  command_exists npm && npm --version || echo "missing"
  printf "Bun:                "
  command_exists bun && bun --version || echo "missing"
  printf "Fish:               "
  command_exists fish && fish --version || echo "missing"
  echo

  print_header "Git"
  if git -C "$DOTFILES_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$DOTFILES_DIR" status --short --branch
    git -C "$DOTFILES_DIR" remote -v
  else
    print_warning "$DOTFILES_DIR is not a git repository"
  fi
}

cmd_doctor() {
  parse_verbose_args "$@" || return 1
  print_header "Running diagnostics"

  local failed=0

  print_verbose "Checking registered tool dependencies"
  for entry in "${TOOL_REGISTRY[@]}"; do
    _parse_tool_entry "$entry"
    [[ "$r_doctor" == "true" ]] || continue

    if [[ "$r_check" == "-" ]]; then
      continue
    fi

    if command_exists "$r_check"; then
      print_success "$r_name"
    elif [[ "$r_required" == "true" ]]; then
      print_error "$r_name is missing"
      failed=1
    else
      print_warning "$r_name is missing"
    fi
  done

  print_verbose "Checking repository layout and executable bits"
  [[ -d "$HOME_DIR" ]] || { print_error "Missing $HOME_DIR"; failed=1; }
  [[ -f "$BASE_BUNDLE" ]] || { print_error "Missing $BASE_BUNDLE"; failed=1; }
  [[ -x "$DOTFILES_DIR/dot" ]] || { print_error "dot is not executable"; failed=1; }
  [[ -x "$DOTFILES_DIR/.githooks/pre-push" ]] || { print_error "pre-push hook is not executable"; failed=1; }

  print_verbose "Checking Git hook configuration"
  if git_hooks_enabled; then
    print_success "Git hooks path"
  else
    print_warning "Git hooks path is not .githooks; run 'dot hooks'"
  fi

  print_verbose "Checking local Git identity configuration"
  if [[ -f "$HOME/.gitconfig.local" ]]; then
    print_success "Git identity config"
  else
    print_warning "Missing ~/.gitconfig.local"
  fi

  print_verbose "Checking managed home symlinks"
  check_managed_links || failed=1
  check_agent_skills_link || failed=1

  print_verbose "Checking shell PATH entries"
  if path_contains "$HOME/.local/bin"; then
    print_success "~/.local/bin is on PATH"
  else
    print_warning "~/.local/bin is not on PATH"
  fi

  print_verbose "Checking pnpm-managed runtime origins"
  check_runtime_origins || failed=1

  print_verbose "Checking pnpm security policy"
  check_pnpm_policy || failed=1

  print_verbose "Checking Homebrew bundle state"
  if ! brew_bundle_check "$BASE_BUNDLE"; then
    failed=1
  fi

  print_verbose "Running repository secret scan"
  if secret_scan; then
    print_error "Possible secrets found"
    failed=1
  else
    print_success "Secret scan passed"
  fi

  if [[ "$failed" -eq 0 ]]; then
    print_success "dotfiles look healthy"
  fi

  return "$failed"
}

cmd_edit() {
  if [[ -n "${EDITOR:-}" ]]; then
    "$EDITOR" "$DOTFILES_DIR"
  elif command_exists code; then
    code "$DOTFILES_DIR"
  else
    echo "$DOTFILES_DIR"
  fi
}

cmd_completions_fish() {
  cat <<'EOF'
complete -c dot -f
complete -c dot -s v -l verbose -d 'Print verbose progress diagnostics'
complete -c dot -s h -l help -d 'Show help'
complete -c dot -l version -d 'Show version'

complete -c dot -n '__fish_use_subcommand' -a init -d 'Initialize and install dotfiles'
complete -c dot -n '__fish_use_subcommand' -a update -d 'Update dotfiles and packages'
complete -c dot -n '__fish_use_subcommand' -a doctor -d 'Run diagnostics'
complete -c dot -n '__fish_use_subcommand' -a info -d 'Show repository and runtime info'
complete -c dot -n '__fish_use_subcommand' -a links -d 'Check managed symlinks'
complete -c dot -n '__fish_use_subcommand' -a hooks -d 'Install repository Git hooks'
complete -c dot -n '__fish_use_subcommand' -a secret-scan -d 'Scan repository for secrets'
complete -c dot -n '__fish_use_subcommand' -a package -d 'Manage Homebrew bundle packages'
complete -c dot -n '__fish_use_subcommand' -a skills -d 'Manage shared global Agent Skills'
complete -c dot -n '__fish_use_subcommand' -a pi -d 'Manage Pi and Pi extensions'
complete -c dot -n '__fish_use_subcommand' -a config -d 'Manage local-only preferences'
complete -c dot -n '__fish_use_subcommand' -a retry-failed -d 'Retry failed package installs'
complete -c dot -n '__fish_use_subcommand' -a git-identity -d 'Create or update local Git identity'
complete -c dot -n '__fish_use_subcommand' -a stow -d 'Create symlinks using GNU Stow'
complete -c dot -n '__fish_use_subcommand' -a unstow -d 'Remove stowed symlinks'
complete -c dot -n '__fish_use_subcommand' -a link -d 'Install dot command globally'
complete -c dot -n '__fish_use_subcommand' -a unlink -d 'Remove global dot command'
complete -c dot -n '__fish_use_subcommand' -a completions -d 'Print shell completions'
complete -c dot -n '__fish_use_subcommand' -a edit -d 'Open dotfiles repo'
complete -c dot -n '__fish_use_subcommand' -a help -d 'Show help'

complete -c dot -n '__fish_seen_subcommand_from package' -a 'list check unmanaged add remove update help' -d 'Package command'
complete -c dot -n '__fish_seen_subcommand_from skills' -a 'add list help' -d 'Skills command'
complete -c dot -n '__fish_seen_subcommand_from pi' -a 'status update extension help' -d 'Pi command'
complete -c dot -n '__fish_seen_subcommand_from config' -a 'list get set unset reset help' -d 'Config command'
EOF
}

cmd_completions() {
  cmd_completions_fish
}

cmd_help() {
  cat <<EOF
${BOLD}${SCRIPT_NAME}${RESET} - Dotfiles management tool
Version: ${VERSION}

${BOLD}USAGE:${RESET}
  ${SCRIPT_NAME} [GLOBAL OPTIONS] COMMAND [ARGS]

${BOLD}GLOBAL OPTIONS:${RESET}
  -v, --verbose    Print progress and decision-point diagnostics
  -h, --help       Show this help
  --version        Show version

${BOLD}COMMANDS:${RESET}
  init             Initialize Homebrew packages, Stow links, and dot CLI
  update           Pull repo changes, update packages, and restow
  doctor           Run diagnostics
  info             Show repository paths, runtime tools, and git status
  links            Check every managed home symlink
  hooks            Install repository Git hooks
  secret-scan      Scan repository for secrets
  package          Package management commands
  skills           Manage shared global Agent Skills
  pi               Manage Pi and Pi extensions
  config           Manage local-only preferences
  retry-failed     Retry failed package installations
  git-identity     Create or update ~/.gitconfig.local
  stow             Create symlinks using GNU Stow
  unstow           Remove symlinks using GNU Stow
  link             Link dot into ~/.local/bin
  unlink           Remove ~/.local/bin/dot
  completions      Print shell completions
  edit             Open the dotfiles repo
  help             Show this help

${BOLD}CONFIGURATION:${RESET}
  Dotfiles directory: ${DOTFILES_DIR}
  Packages directory: ${PACKAGES_DIR}
  Home directory:     ${HOME_DIR}
EOF
}

main() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      -v|--verbose)
        DOT_VERBOSE=true
        shift
        ;;
      --)
        shift
        break
        ;;
      *) break ;;
    esac
  done

  local command="${1:-help}"
  if [[ "$#" -gt 0 ]]; then
    shift
  fi

  case "$command" in
    --version) echo "${SCRIPT_NAME} version ${VERSION}" ;;
    -h|--help|help) cmd_help ;;
    init) cmd_init "$@" ;;
    update) cmd_update "$@" ;;
    doctor) cmd_doctor "$@" ;;
    info) cmd_info "$@" ;;
    links) cmd_links "$@" ;;
    hooks) cmd_hooks "$@" ;;
    secret-scan) cmd_secret_scan "$@" ;;
    package) cmd_package "$@" ;;
    skills) cmd_skills "$@" ;;
    pi) cmd_pi "$@" ;;
    config) cmd_config "$@" ;;
    retry-failed) cmd_retry_failed "$@" ;;
    git-identity) cmd_git_identity "$@" ;;
    stow) cmd_stow "$@" ;;
    unstow) cmd_unstow "$@" ;;
    link) cmd_link "$@" ;;
    unlink) cmd_unlink "$@" ;;
    completions) cmd_completions "$@" ;;
    edit) cmd_edit "$@" ;;
    *) print_error "Unknown command: $command"; cmd_help; return 1 ;;
  esac
}

main "$@"
