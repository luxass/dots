#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="dot"
readonly VERSION="1.2.0"
SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
readonly SCRIPT_PATH
DOTFILES_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
readonly DOTFILES_DIR
readonly PACKAGES_DIR="${DOTFILES_DIR}/packages"
readonly HOME_DIR="${DOTFILES_DIR}/home"
readonly BASE_BUNDLE="${PACKAGES_DIR}/bundle"
readonly FONTS_BUNDLE="${PACKAGES_DIR}/bundle.fonts"
readonly WORK_BUNDLE="${PACKAGES_DIR}/bundle.work"
readonly BACKUP_ROOT="${DOTFILES_DIR}/backups"
readonly PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
readonly NODE_RUNTIME_VERSION="${NODE_RUNTIME_VERSION:-lts}"
readonly PNPM_GLOBAL_PACKAGES=("sfw" "@earendil-works/pi-coding-agent:pi")

CURRENT_STEP=0
TOTAL_STEPS=0

source "${DOTFILES_DIR}/lib/core.sh"
source "${DOTFILES_DIR}/lib/brew.sh"
source "${DOTFILES_DIR}/lib/runtime.sh"
source "${DOTFILES_DIR}/lib/stow.sh"
source "${DOTFILES_DIR}/lib/git.sh"

TOOL_REGISTRY=(
  "Homebrew          ;; brew ;; fn:ensure_homebrew             ;; true  ;; - ;; true"
  "Brewfile packages ;; -    ;; fn:_install_packages           ;; true  ;; - ;; false"
  "Stow dotfiles     ;; -    ;; fn:_stow_dotfiles              ;; true  ;; - ;; false"
  "pnpm              ;; pnpm ;; fn:ensure_pnpm                 ;; true  ;; - ;; true"
  "Node.js runtime   ;; node ;; fn:ensure_node_runtime         ;; true  ;; - ;; true"
  "pnpm globals      ;; -    ;; fn:ensure_pnpm_globals         ;; true  ;; - ;; false"
  "Git hooks         ;; -    ;; fn:ensure_git_hooks            ;; false ;; - ;; false"
  "Git identity      ;; -    ;; fn:ensure_gitconfig_local      ;; false ;; - ;; false"
  "dot CLI           ;; dot  ;; fn:_link_dot                   ;; true  ;; - ;; true"
  "Git               ;; git  ;; -                              ;; true  ;; - ;; true"
  "GNU Stow          ;; stow ;; fn:ensure_stow                 ;; true  ;; - ;; true"
  "Starship          ;; starship ;; -                          ;; false ;; - ;; true"
  "Zoxide            ;; zoxide ;; -                            ;; false ;; - ;; true"
  "Bun               ;; bun  ;; -                              ;; false ;; - ;; true"
  "Socket Firewall   ;; sfw  ;; -                              ;; false ;; - ;; true"
  "Pi                ;; pi   ;; -                              ;; false ;; - ;; true"
)

_parse_tool_entry() {
  local entry="$1"
  r_name="$(echo "$entry" | awk -F';;' '{print $1}' | xargs)"
  r_check="$(echo "$entry" | awk -F';;' '{print $2}' | xargs)"
  r_install="$(echo "$entry" | awk -F';;' '{print $3}' | xargs)"
  r_required="$(echo "$entry" | awk -F';;' '{print $4}' | xargs)"
  r_skip="$(echo "$entry" | awk -F';;' '{print $5}' | xargs)"
  r_doctor="$(echo "$entry" | awk -F';;' '{print $6}' | xargs)"
}

run_init_steps() {
  TOTAL_STEPS=0
  for entry in "${TOOL_REGISTRY[@]}"; do
    _parse_tool_entry "$entry"
    if [[ "$r_skip" != "-" && "${!r_skip:-}" == "true" ]]; then
      continue
    fi
    ((++TOTAL_STEPS))
  done

  CURRENT_STEP=0
  for entry in "${TOOL_REGISTRY[@]}"; do
    _parse_tool_entry "$entry"
    if [[ "$r_skip" != "-" && "${!r_skip:-}" == "true" ]]; then
      continue
    fi

    print_step "$r_name"
    if [[ "$r_install" == fn:* ]]; then
      local fn="${r_install#fn:}"
      if "$fn"; then
        true
      elif [[ "$r_required" == "true" ]]; then
        return 1
      else
        print_warning "$r_name failed; continuing"
      fi
    elif [[ "$r_check" != "-" ]] && command_exists "$r_check"; then
      print_success "$r_name is installed"
    elif [[ "$r_required" == "true" ]]; then
      print_error "$r_name is missing"
      return 1
    else
      print_warning "$r_name is missing"
    fi
  done
}

cmd_init() {
  print_header "Initializing dotfiles"
  run_init_steps
}

cmd_update() {
  print_header "Updating dotfiles"

  if git -C "$DOTFILES_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    print_info "Pulling latest repo changes"
    git -C "$DOTFILES_DIR" pull --ff-only
  fi

  print_info "Updating Homebrew"
  brew update
  brew_bundle_install_resilient "$BASE_BUNDLE"
  _stow_dotfiles
}

cmd_info() {
  print_header "Dotfiles"
  echo "Version:            $VERSION"
  echo "Dotfiles directory: $DOTFILES_DIR"
  echo "Home package:       $HOME_DIR"
  echo "Packages:           $PACKAGES_DIR"
  echo "Backups:            $BACKUP_ROOT"
  echo

  print_header "Runtime"
  printf "Homebrew:           "
  command_exists brew && command -v brew || echo "missing"
  printf "pnpm:               "
  command_exists pnpm && command -v pnpm || echo "missing"
  printf "Node.js:            "
  command_exists node && node --version || echo "missing"
  printf "npm:                "
  command_exists npm && npm --version || echo "missing"
  printf "Bun:                "
  command_exists bun && bun --version || echo "missing"
  echo

  print_header "Git"
  if git -C "$DOTFILES_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$DOTFILES_DIR" status --short --branch
    git -C "$DOTFILES_DIR" remote -v
  else
    print_warning "$DOTFILES_DIR is not a git repository"
  fi
}

cmd_doctor() {
  print_header "Running diagnostics"

  local failed=0

  for entry in "${TOOL_REGISTRY[@]}"; do
    _parse_tool_entry "$entry"
    [[ "$r_doctor" == "true" ]] || continue

    if [[ "$r_check" == "-" ]]; then
      continue
    fi

    if command_exists "$r_check"; then
      print_success "$r_name"
    elif [[ "$r_required" == "true" ]]; then
      print_error "$r_name is missing"
      failed=1
    else
      print_warning "$r_name is missing"
    fi
  done

  [[ -d "$HOME_DIR" ]] || { print_error "Missing $HOME_DIR"; failed=1; }
  [[ -f "$BASE_BUNDLE" ]] || { print_error "Missing $BASE_BUNDLE"; failed=1; }
  [[ -x "$DOTFILES_DIR/dot" ]] || { print_error "dot is not executable"; failed=1; }
  [[ -x "$DOTFILES_DIR/.githooks/pre-push" ]] || { print_error "pre-push hook is not executable"; failed=1; }

  if git_hooks_enabled; then
    print_success "Git hooks path"
  else
    print_warning "Git hooks path is not .githooks; run 'dot hooks'"
  fi

  if [[ -f "$HOME/.gitconfig.local" ]]; then
    print_success "Git identity config"
  else
    print_warning "Missing ~/.gitconfig.local"
  fi

  check_managed_links false || failed=1

  if path_contains "$HOME/.local/bin"; then
    print_success "~/.local/bin is on PATH"
  else
    print_warning "~/.local/bin is not on PATH"
  fi

  check_runtime_origins || failed=1
  check_pnpm_policy || failed=1

  if ! brew_bundle_check "$BASE_BUNDLE"; then
    failed=1
  fi

  if secret_scan; then
    print_error "Possible secrets found"
    failed=1
  else
    print_success "Secret scan passed"
  fi

  if [[ "$failed" -eq 0 ]]; then
    print_success "dotfiles look healthy"
  fi

  return "$failed"
}

cmd_edit() {
  if [[ -n "${EDITOR:-}" ]]; then
    "$EDITOR" "$DOTFILES_DIR"
  elif command_exists code; then
    code "$DOTFILES_DIR"
  else
    echo "$DOTFILES_DIR"
  fi
}

cmd_completions() {
  cat <<'EOF'
#compdef dot
_dot() {
  local -a commands
  commands=(
    'init:Initialize and install dotfiles'
    'update:Update dotfiles and packages'
    'doctor:Run diagnostics'
    'info:Show repository and runtime info'
    'links:Check managed symlinks'
    'hooks:Install repository Git hooks'
    'secret-scan:Scan repository for secrets'
    'package:Manage Homebrew bundle packages'
    'check-packages:Check bundle package state'
    'retry-failed:Retry failed package installs'
    'git-identity:Create or update local Git identity'
    'stow:Create symlinks using GNU Stow'
    'unstow:Remove stowed symlinks'
    'link:Install dot command globally'
    'unlink:Remove global dot command'
    'edit:Open dotfiles repo'
    'help:Show help'
  )
  _describe 'command' commands
}
_dot "$@"
EOF
}

cmd_help() {
  cat <<EOF
${BOLD}${SCRIPT_NAME}${RESET} - Dotfiles management tool
Version: ${VERSION}

${BOLD}USAGE:${RESET}
  ${SCRIPT_NAME} COMMAND [ARGS]

${BOLD}COMMANDS:${RESET}
  init             Initialize Homebrew packages, Stow links, and dot CLI
  update           Pull repo changes, update packages, and restow
  doctor           Run diagnostics
  info             Show repository paths, runtime tools, and git status
  links            Check every managed home symlink
  hooks            Install repository Git hooks
  secret-scan      Scan repository for secrets
  package          Package management commands
  check-packages   Check installed package state
  retry-failed     Retry failed package installations
  git-identity     Create or update ~/.gitconfig.local
  stow             Create symlinks using GNU Stow
  unstow           Remove symlinks using GNU Stow
  link             Link dot into ~/.local/bin
  unlink           Remove ~/.local/bin/dot
  completions      Print zsh completions
  edit             Open the dotfiles repo
  help             Show this help

${BOLD}CONFIGURATION:${RESET}
  Dotfiles directory: ${DOTFILES_DIR}
  Packages directory: ${PACKAGES_DIR}
  Home directory:     ${HOME_DIR}
EOF
}

main() {
  case "${1:-help}" in
    --version) echo "${SCRIPT_NAME} version ${VERSION}" ;;
    -h|--help|help) cmd_help ;;
    init) shift; cmd_init "$@" ;;
    update) shift; cmd_update "$@" ;;
    doctor) shift; cmd_doctor "$@" ;;
    info) shift; cmd_info "$@" ;;
    links) shift; cmd_links "$@" ;;
    hooks) shift; cmd_hooks "$@" ;;
    secret-scan) shift; cmd_secret_scan "$@" ;;
    package) shift; cmd_package "$@" ;;
    check-packages) shift; cmd_check_packages "$@" ;;
    retry-failed) shift; cmd_retry_failed "$@" ;;
    git-identity) shift; cmd_git_identity "$@" ;;
    stow) shift; cmd_stow "$@" ;;
    unstow) shift; cmd_unstow "$@" ;;
    link) shift; cmd_link "$@" ;;
    unlink) shift; cmd_unlink "$@" ;;
    completions) shift; cmd_completions "$@" ;;
    edit) shift; cmd_edit "$@" ;;
    *) print_error "Unknown command: $1"; cmd_help; return 1 ;;
  esac
}

main "$@"
